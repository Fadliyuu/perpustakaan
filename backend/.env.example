# =================================================================
# BACKEND ENVIRONMENT VARIABLES
# Copy file ini menjadi .env di dalam folder backend lalu isi nilainya.
# =================================================================

# Server Configuration (Opsional)
PORT=4000
HOST=0.0.0.0

# Keamanan (Wajib Diisi)
JWT_SECRET=your_jwt_secret_key_here

# Mode Development (Opsional: '1' untuk aktifkan pembuat user admin default)
ENABLE_DEV_ADMIN=1

# Firebase Admin SDK Credentials (Pilih salah satu opsi)
# Opsi 1: Kredensial Individu (Direkomendasikan untuk Vercel/Railway)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Ganti \n dengan newlines atau tempel langsung private key Anda
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Opsi 2: Service Account JSON String
# FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": ...}'

# Opsi 3: File Path untuk Google Application Credentials (Lokal)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-key.json

# Cloudinary Configuration (Wajib untuk upload gambar/cover buku)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
